// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum VenueType {
  FUTBOL_5
  FUTBOL_7
  FUTBOL_8
  FUTBOL_9
  PADEL
}

// Reemplaza a `Venue.active` (booleano). MANTENIMIENTO se trata igual que INACTIVA para todo lo que
// mira disponibilidad (no reservable, no aparece en público) pero es un estado real y distinguible
// en el panel admin en vez de derivarse de si hay bloqueos de horario vigentes.
enum VenueStatus {
  ACTIVA
  MANTENIMIENTO
  INACTIVA
}

// Máquina de estados de negocio.md §6.1
enum BookingStatus {
  PENDIENTE_PAGO
  CONFIRMADA
  EN_CURSO
  FINALIZADA
  CANCELADA
  NO_SHOW
  EXPIRADA
  // Cancha con Venue.requiresPayment=false: el cliente mandó sus datos sin pagar abono. No bloquea
  // el cupo (no entra en BLOCKING_STATUSES) — el admin debe confirmarla a mano para que sí lo
  // reclame. Ver lib/booking/state-machine.ts.
  SOLICITADA
}

enum PaymentMethod {
  BOLD
  COMPROBANTE_MANUAL
}

// negocio.md §6.4
enum UserRole {
  ADMIN
  // Rol global de plataforma, sin organización propia (User.orgId queda null) — gestiona el
  // catálogo de organizaciones (tenants) y puede entrar al panel admin de cualquiera. No se puede
  // asignar desde /admin/usuarios (ese formulario solo acepta ADMIN/EMPLOYEE) — solo vía
  // /superadmin o el seed script.
  SUPERADMIN
  EMPLOYEE
}

enum CashShiftStatus {
  ABIERTO
  EN_DISPUTA
  CERRADO
}

// Cómo se pagó el saldo restante + consumos al cerrar la cuenta de una reserva (negocio.md §3/§4).
enum SettlementMethod {
  EFECTIVO
  TRANSFERENCIA
  DATAFONO
}

// Quién/qué disparó la cancelación (negocio.md §6.2) — para mostrarle al cliente "quién canceló" en
// la página de confirmación y para reportes.
enum CancelledBy {
  CUSTOMER
  ADMIN
  EMPLOYEE
  SYSTEM
}

// Motivo de la reserva, capturado solo cuando el admin la crea manualmente (drawer "Nueva reserva" /
// wizard de recurrentes) — el flujo público del cliente siempre es PARTICULAR implícito, por eso no
// se pide ahí.
enum BookingType {
  PARTICULAR
  TORNEO
  CLASE
}

model Organization {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  slug                    String   @unique
  name                    String
  logoUrl                 String?
  country                 String   @default("Colombia")
  department              String?
  municipality            String?
  address                 String?
  phone                   String?
  contactEmail            String?
  website                 String?
  description             String?
  latitude                Float?
  longitude               Float?
  timezone                String   @default("America/Bogota")
  depositPercentage       Int      @default(50)
  cancellationWindowHours Int      @default(24)
  bookingHoldMinutes      Int      @default(15)
  createdAt               DateTime @default(now())

  venues            Venue[]
  bookings          Booking[]
  recurringBookings RecurringBooking[]
  users             User[]
  consumptionItems  ConsumptionItem[]
  cashShifts        CashShift[]
  slotBlocks        SlotBlock[]
  auditLogs         AuditLog[]
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  // Null solo para SUPERADMIN — todo ADMIN/EMPLOYEE pertenece a una organización.
  orgId        String?  @db.ObjectId
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(EMPLOYEE)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  organization Organization? @relation(fields: [orgId], references: [id])
  cashShifts   CashShift[]

  @@index([orgId])
}

model ConsumptionItem {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  orgId             String  @db.ObjectId
  name              String
  price             Int
  stock             Int
  lowStockThreshold Int     @default(10)
  active            Boolean @default(true)

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

model CashShift {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  orgId       String          @db.ObjectId
  employeeId  String          @db.ObjectId
  openingCash Int
  openedAt    DateTime        @default(now())
  closedAt    DateTime?
  status      CashShiftStatus @default(ABIERTO)

  // Conciliación automática (negocio.md §4): calculada al solicitar el cierre, antes de que el
  // empleado vea nada ("reporte a ciegas").
  expectedCourtsTotal Int?
  expectedBarTotal    Int?
  expectedCash        Int?
  expectedTransfer    Int?
  expectedCard        Int?
  countedCash         Int?
  discrepancy         Int?

  // Disputa (negocio.md §6.5): solo el ADMIN puede reabrir/ajustar; cada ajuste queda en un log
  // inmutable (nunca se sobrescribe ni se borra) y el descuadre solo se resuelve explícitamente.
  adjustments    CashShiftAdjustment[]
  resolvedAt     DateTime?
  resolvedByName String?

  organization Organization @relation(fields: [orgId], references: [id])
  employee     User         @relation(fields: [employeeId], references: [id])

  @@index([orgId, employeeId])
}

type CashShiftAdjustment {
  previousCountedCash Int
  newCountedCash      Int
  reason              String
  adjustedByName      String
  adjustedAt          DateTime
}

type ConsumptionLine {
  productId   String @db.ObjectId
  productName String
  unitPrice   Int
  quantity    Int
}

model Venue {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  orgId      String    @db.ObjectId
  name       String
  type       VenueType
  hourlyRate Int
  imageUrl   String? // legado: foto única, queda solo como fallback de lectura para canchas viejas
  imageUrls  String[]  @default([])
  capacity   Int?
  status     VenueStatus @default(ACTIVA)

  // false = "Solicitud sin pago": el flujo público se salta abono/Bold/comprobante y crea la
  // reserva como SOLICITADA (no bloquea el cupo) hasta que el admin la confirme a mano. Ver
  // createBookingShell/submitBookingRequest (lib/booking/actions.ts) y confirmSolicitud
  // (lib/admin/actions.ts).
  requiresPayment Boolean @default(true)

  // Canchas combinables (ej. una de Fútbol 9 que también se usa como 2 de Fútbol 7): esta cancha no
  // tiene franja física propia, reclama las de las canchas listadas acá al reservarse (ver
  // lib/booking/slot-locks.ts). Vacío en las canchas "atómicas" (F7-A, F7-B), que sí son dueñas de
  // su propia franja.
  linkedVenueIds String[] @default([])

  // Ficha de detalle (página admin/canchas/[venueId] y página pública de la cancha) — todos
  // opcionales porque las canchas creadas antes de este campo quedan vacías hasta que el admin las
  // completa desde el panel de edición.
  surface           String? // "Césped sintético", "Cristal", etc.
  coverage          String? // "Al aire libre" | "Cubierta" | "Semi-cubierta"
  locationInComplex String? // texto libre, ej. "Zona Norte"
  description       String? // texto libre para la página pública/detalle
  amenities         String[] @default([]) // slugs de lib/venues/amenities.ts, reales por cancha

  organization      Organization       @relation(fields: [orgId], references: [id])
  bookings          Booking[]
  slotBlocks        SlotBlock[]
  recurringBookings RecurringBooking[]
  priceRules        VenuePriceRule[]

  @@index([orgId])
}

// Excepción al precio por defecto (Venue.hourlyRate) para un día de la semana + rango horario
// puntual (ej. "Sábado 18:00-22:00 → $60.000"). Sin solape permitido entre reglas de una misma
// cancha (ver rulesOverlap en lib/booking/pricing.ts, validado al crear) — así nunca hay ambigüedad
// sobre qué precio se cobra en un turno dado.
model VenuePriceRule {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  venueId   String   @db.ObjectId
  dayOfWeek Int // 0=domingo..6=sábado, coincide con Date.getUTCDay()
  startTime String // "HH:mm", hora exacta (mismo grid que los turnos)
  endTime   String // "HH:mm", límite superior exclusivo
  price     Int
  createdAt DateTime @default(now())

  venue Venue @relation(fields: [venueId], references: [id])

  @@index([venueId, dayOfWeek])
}

// Horario bloqueado manualmente por el admin (ej. mantenimiento, luces dañadas) — no es una
// reserva de cliente, por eso vive separado de Booking en vez de mezclar estados.
model SlotBlock {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  orgId     String   @db.ObjectId
  venueId   String   @db.ObjectId
  date      DateTime
  startTime String
  reason    String?
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  venue        Venue        @relation(fields: [venueId], references: [id])

  @@unique([venueId, date, startTime])
  @@index([orgId, venueId, date])
}

// Serie de reservas recurrentes creada por el admin (ej. "cliente fijo todos los martes 6pm").
// Solo guarda la regla; cada turno real es un Booking individual (recurringBookingId) generado de
// una sola vez al crear la serie, ya CONFIRMADA y sin abono — el admin la crea directo, no pasa por
// el flujo de pago del cliente. No hay renovación automática: el admin define startDate/endDate y
// esas son todas las ocurrencias que van a existir.
model RecurringBooking {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  orgId   String @db.ObjectId
  venueId String @db.ObjectId

  customerName  String
  customerPhone String

  startTime String // "HH:mm"
  endTime   String // "HH:mm"
  startDate DateTime // primera ocurrencia
  endDate   DateTime // última ocurrencia permitida (inclusive)

  bookingType BookingType?
  notes       String?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  venue        Venue        @relation(fields: [venueId], references: [id])
  bookings     Booking[]

  @@index([orgId, venueId])
}

model Booking {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  orgId   String @db.ObjectId
  venueId String @db.ObjectId

  // Presente solo en ocurrencias generadas por una reserva recurrente (ver RecurringBooking).
  recurringBookingId String? @db.ObjectId

  customerName  String
  customerPhone String
  customerEmail String?

  date      DateTime // día del turno (medianoche local normalizada a UTC)
  startTime String // "HH:mm"
  endTime   String // "HH:mm"

  status BookingStatus @default(PENDIENTE_PAGO)

  // Solo se captura cuando el admin crea la reserva manualmente (drawer/wizard) — ver BookingType.
  bookingType BookingType?
  notes       String?

  // Anti-overbooking (negocio.md §6.3): mientras el estado bloquea el cupo (PENDIENTE_PAGO/CONFIRMADA/
  // EN_CURSO) vale "<venueId>_<date>_<startTime>"; Prisma en MongoDB no soporta índices únicos
  // sparse/parciales, así que al pasar a un estado terminal se reemplaza por "released_<bookingId>"
  // (único por documento) para nunca chocar con el índice @unique de abajo. SOLICITADA usa la misma
  // idea con otro prefijo ("solicitud_<bookingId>", computeSolicitudSlotKey) — no es terminal (puede
  // pasar a CONFIRMADA, que ahí sí reclama la clave real) pero tampoco debe bloquear el cupo.
  blockingSlotKey String @unique

  totalAmount   Int
  depositAmount Int

  // Consumo de barra (negocio.md §3): embebido en la reserva porque pertenece a la cuenta de esa
  // cancha/turno, no a un catálogo compartido — el catálogo de productos vive en ConsumptionItem.
  consumptionLines ConsumptionLine[]
  consumptionTotal Int               @default(0)

  paymentMethod  PaymentMethod?
  boldPaymentRef String?
  receiptUrl     String? // comprobante subido a Azure Blob (Nequi/Daviplata)

  // Cómo pagó el cliente el saldo restante + consumos al cerrar la cuenta (closeAccount, Fase 2).
  // Distinto de paymentMethod, que es el canal del abono inicial.
  settlementMethod SettlementMethod?

  expiresAt DateTime? // vence si sigue en PENDIENTE_PAGO después de esta hora

  // Cancelación (negocio.md §6.2): quién la disparó, cuándo, y el resultado de
  // computeCancellationOutcome (dentro-de-ventana / tardía / no-show) para mostrarlo en la página de
  // confirmación y en reportes. Nulos en reservas canceladas/expiradas/no-show anteriores a este
  // campo (Mongo no tiene migraciones — los documentos viejos simplemente no lo tienen).
  cancelledAt        DateTime?
  cancelledBy        CancelledBy?
  cancellationReason String? // "within_window" | "late_cancellation" | "no_show" | otro

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization      @relation(fields: [orgId], references: [id])
  venue            Venue             @relation(fields: [venueId], references: [id])
  recurringBooking RecurringBooking? @relation(fields: [recurringBookingId], references: [id])

  @@index([orgId, venueId, date])
  @@index([recurringBookingId])
}

// Reclamo de una franja física para una reserva — solo se usa para canchas combinables
// (Venue.linkedVenueIds no vacío). Una cancha normal nunca genera filas acá. El índice único en
// `key` es lo que hace imposible la condición de carrera entre, ej., una cancha de Fútbol 9 y las
// 2 de Fútbol 7 en las que se puede dividir — igual que blockingSlotKey en Booking, nunca se
// "chequea y luego escribe": se intenta escribir y Mongo rechaza el choque.
model SlotLock {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique // "<venueId>_<date>_<startTime>" — mismo formato que blockingSlotKey
  bookingId String   @db.ObjectId
  createdAt DateTime @default(now())

  @@index([bookingId])
}

// Cuenta de cliente final (sin contraseña) — se crea sola apenas alguien completa nombre+WhatsApp en
// una reserva (ver updateBookingContact). Permite "Mis reservas": ver todas sus reservas en
// cualquier organización iniciando sesión solo con el número de WhatsApp + código de un solo uso.
model Customer {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  phone     String   @unique
  name      String
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Código de un solo uso para el login de clientes por WhatsApp (ver lib/customer-auth/actions.ts).
// Vive separado de Customer porque es efímero (expira a los 5 minutos) y puede haber varios
// intentos antes de que exista una cuenta real detrás del teléfono.
model CustomerLoginCode {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  phone     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone])
}

// Auditoría de acciones sensibles del admin (negocio.md: blindar contra fugas/fraude) — cambios de
// precio, rol, stock, contraseña. Separado de CashShiftAdjustment (que ya audita disputas de caja
// con su propio detalle) para tener una sola línea de tiempo legible de "quién hizo qué".
model AuditLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orgId       String   @db.ObjectId
  actorUserId String   @db.ObjectId
  actorName   String
  action      String
  summary     String
  createdAt   DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
}
